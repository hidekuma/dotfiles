export PATH="$HOME/.local/bin:$PATH"
# check mac m1
if [[ $(uname -m) == 'arm64' ]]; then
    eval $(/opt/homebrew/bin/brew shellenv)
fi

# CHECK PLATFORM
[ -z ${PLATFORM+x}  ] && export PLATFORM=$(uname -s)
if [ "$PLATFORM" = 'Darwin'  ]; then
    # MAC
    # mysql
    # export PATH="/usr/local/opt/mysql@5.7/bin:$PATH"
    export EDITOR=nvim
else
    # Else
    export EDITOR=vim
fi

export FZF_TMUX=1
export PATH="/usr/local/sbin:$PATH"

# Pyenv (Python) вАФ lazy loaded for fast startup
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/shims:$PYENV_ROOT/bin:$PATH"
export PYTHON_CONFIGURE_OPTS="--enable-shared"

_load_pyenv() {
  unset -f pyenv
  eval "$(command pyenv init - zsh)"
}

pyenv() { _load_pyenv; pyenv "$@" }

# Rbenv (Ruby)
# export PATH="$HOME/.rbenv/bin:$PATH"
# eval "$(rbenv init -)"

# Jenv (Java)
# export PATH="$HOME/.jenv/bin:$PATH"
# eval "$(jenv init -)"

# Nvm (Node Version Manager) вАФ lazy loaded for fast startup
export NVM_DIR="$HOME/.nvm"

_load_nvm() {
  unset -f nvm node npm npx corepack
  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
  [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
}

for cmd in nvm node npm npx corepack; do
  eval "${cmd}() { _load_nvm; ${cmd} \"\$@\" }"
done

# Virtualenv & Virtualenv Wrapper вАФ lazy loaded for fast startup
export WORKON_HOME=~/.virtualenvs

_load_virtualenvwrapper() {
  unset -f workon mkvirtualenv rmvirtualenv deactivate
  export VIRTUALENVWRAPPER_PYTHON=$(which python3)
  export VIRTUALENVWRAPPER_VIRTUALENV=~/.local/bin/virtualenv
  source ~/.local/bin/virtualenvwrapper.sh
}

for cmd in workon mkvirtualenv rmvirtualenv deactivate; do
  eval "${cmd}() { _load_virtualenvwrapper; ${cmd} \"\$@\" }"
done

# claude
export ENABLE_EXPERIMENTAL_MCP_CLI=true

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
